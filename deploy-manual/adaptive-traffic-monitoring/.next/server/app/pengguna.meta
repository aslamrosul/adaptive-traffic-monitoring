{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pengguna/layout,_N_T_/pengguna/page,_N_T_/pengguna"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pengguna/__PAGE__",
    "/pengguna",
    "/_index",
    "/_head"
  ]
}