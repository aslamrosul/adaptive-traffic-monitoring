# Database
DATABASE_URL="postgresql://user:password@localhost:5432/traffic_monitoring"

# ESP32 IoT Configuration
ESP32_API_KEY="your-api-key-here"
MQTT_BROKER_URL="mqtt://broker.example.com:1883"
