# Cloud Storage (Azure/GCP)
AZURE_STORAGE_CONNECTION_STRING="your-azure-connection-string"
# OR
GCP_PROJECT_ID="your-gcp-project-id"
GCP_STORAGE_BUCKET="your-bucket-name"

# Next Auth (untuk authentication)
